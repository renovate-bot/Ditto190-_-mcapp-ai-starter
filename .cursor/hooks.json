{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "type": "command",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook user-prompt-submit",
        "type": "command",
        "timeout": 5
      },
      {
        "command": "npx -y @contextstream/mcp-server@latest hook on-save-intent",
        "type": "command",
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "type": "command",
        "timeout": 5
      }
    ],
    "afterMCPExecution": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook post-tool-use",
        "type": "command",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "type": "command",
        "timeout": 5
      }
    ],
    "afterShellExecution": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook post-tool-use-failure",
        "type": "command",
        "timeout": 10
      }
    ],
    "beforeReadFile": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "type": "command",
        "timeout": 5
      }
    ],
    "afterFileEdit": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook post-tool-use",
        "type": "command",
        "timeout": 10
      }
    ],
    "preCompact": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-compact",
        "type": "command",
        "timeout": 15
      }
    ],
    "sessionStart": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook session-start",
        "type": "command",
        "timeout": 15
      }
    ],
    "sessionEnd": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook session-end",
        "type": "command",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook stop",
        "type": "command",
        "timeout": 15
      }
    ],
    "subagentStart": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook subagent-start",
        "type": "command",
        "timeout": 10
      }
    ],
    "subagentStop": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook subagent-stop",
        "type": "command",
        "timeout": 10
      }
    ],
    "taskCompleted": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook task-completed",
        "type": "command",
        "timeout": 10
      }
    ],
    "teammateIdle": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook teammate-idle",
        "type": "command",
        "timeout": 10
      }
    ],
    "notification": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook notification",
        "type": "command",
        "timeout": 10
      }
    ],
    "permissionRequest": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook permission-request",
        "type": "command",
        "timeout": 10
      }
    ]
  }
}