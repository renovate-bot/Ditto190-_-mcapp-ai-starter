{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Multi-provider LLM configuration for the AI Starter Kit. Copy to llm.config.local.json and fill in your API keys.",
  "default_provider": "ollama",
  "providers": {
    "ollama": {
      "enabled": true,
      "base_url": "http://localhost:11434",
      "default_model": "phi:latest",
      "models": ["phi:latest", "llama3.2", "mistral", "deepseek-r1"],
      "notes": "Local inference — no API key required. Runs inside Docker (CPU profile)."
    },
    "openai": {
      "enabled": false,
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "default_model": "gpt-5-mini",
      "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-3.5-turbo"],
      "notes": "Set OPENAI_API_KEY in your .env file to enable."
    },
    "anthropic": {
      "enabled": false,
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "default_model": "claude-3-5-haiku-20241022",
      "models": [
        "claude-opus-4-5",
        "claude-sonnet-4-5",
        "claude-3-5-haiku-20241022"
      ],
      "notes": "Set ANTHROPIC_API_KEY in your .env file to enable."
    },
    "google": {
      "enabled": false,
      "base_url": "https://generativelanguage.googleapis.com",
      "api_key_env": "GEMINI_API_KEY",
      "default_model": "gemini-2.0-flash",
      "models": ["gemini-2.5-pro", "gemini-2.0-flash", "gemini-1.5-pro"],
      "notes": "Set GEMINI_API_KEY in your .env file to enable."
    },
    "openrouter": {
      "enabled": false,
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "default_model": "meta-llama/llama-3.2-3b-instruct:free",
      "models": [
        "meta-llama/llama-3.2-3b-instruct:free",
        "microsoft/phi-3-medium-128k-instruct:free",
        "google/gemma-2-9b-it:free"
      ],
      "notes": "Set OPENROUTER_API_KEY in .env. Free tier has many open-source models."
    }
  },
  "n8n_integration": {
    "ollama_credential_name": "Ollama account",
    "ollama_base_url": "http://ollama:11434",
    "notes": "In n8n workflows, use the credential name above for Ollama nodes. Other providers require API credentials added via n8n UI."
  },
  "generateagents_defaults": {
    "preferred_model": "gpt-5-mini",
    "fallback_model": "gemini/gemini-2.0-flash",
    "style": "comprehensive"
  }
}
