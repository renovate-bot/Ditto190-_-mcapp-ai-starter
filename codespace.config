# Codespace Connection Config Template
# Copy this file and customize for your local agent environment

[codespace]
# This Codespace's metadata
name = "curly-space-spork-v9rg679gpqw3rj6"
domain = "app.github.dev"

[services.n8n]
# Workflow automation & orchestration
base_url = "https://curly-space-spork-v9rg679gpqw3rj6-5678.app.github.dev"
api_key = "${N8N_API_KEY}"  # Set via environment variable: export N8N_API_KEY="..."
header_format = "X-N8N-API-KEY"

# Available endpoints
endpoints = {
    "list_workflows": "/api/v1/workflows",
    "create_workflow": "/api/v1/workflows",
    "execute_workflow": "/api/v1/workflows/{id}/execute",
    "get_workflow": "/api/v1/workflows/{id}",
    "list_executions": "/api/v1/executions"
}

[services.ollama]
# Local LLM inference
base_url = "https://curly-space-spork-v9rg679gpqw3rj6-11434.app.github.dev"
default_model = "llama3.2"
available_models = ["llama3.2", "mistral", "neural-chat"]

# Endpoints
endpoints = {
    "generate": "/api/generate",
    "list_models": "/api/tags",
    "pull_model": "/api/pull",
    "health": "/api/health"
}

[services.qdrant]
# Vector database for embeddings & RAG
url = "https://curly-space-spork-v9rg679gpqw3rj6-6333.app.github.dev"
default_collection = "embeddings"

# Endpoints
endpoints = {
    "health": "/health",
    "collections": "/collections",
    "create_collection": "/collections/{name}",
    "upsert": "/collections/{collection}/points",
    "search": "/collections/{collection}/points/search"
}

[services.postgres]
# Database for n8n workflows, metadata, etc.
host = "localhost"  # Use after SSH tunnel setup
port = 5432
user = "root"
password = "${POSTGRES_PASSWORD}"  # Set via environment variable
database = "n8n"

# Connection string for psycopg2/sqlalchemy
connection_string = "postgresql://root:${POSTGRES_PASSWORD}@localhost:5432/n8n"

[services.generateagents]
# Code analysis & AGENTS.md generation
type = "mcp"  # Model Context Protocol
local_repo_path = "/workspaces/self-hosted-ai-starter-kit/GenerateAgents.md"

# For HTTP bridge (requires additional setup in Codespace)
# http_endpoint = "https://curly-space-spork-v9rg679gpqw3rj6-8765.app.github.dev"

# Available tools
tools = [
    "list_models",
    "generate_agents",
    "generate_agents_from_github",
    "validate_output",
    "run_tests"
]

# Supported LLM models
supported_models = [
    "gemini/gemini-2.5-pro",
    "anthropic/claude-3-opus",
    "openai/gpt-4",
    "ollama/llama3.2"
]

[authentication]
# Environment variables required for external agent access
required_env_vars = [
    "N8N_API_KEY",
    "POSTGRES_PASSWORD",
    "CODESPACE_NAME"
]

# Optional for GenerateAgents
optional_env_vars = [
    "GEMINI_API_KEY",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY"
]

[ssh_tunnel]
# For PostgreSQL access from local machine
# Usage: gh codespace ports forward --codespace {name} 5432:5432
description = "SSH tunnel required for local PostgreSQL access"
command = "gh codespace ports forward --codespace curly-space-spork-v9rg679gpqw3rj6 5432:5432"

[health_checks]
# Test endpoints to verify connectivity
n8n_health = "https://curly-space-spork-v9rg679gpqw3rj6-5678.app.github.dev/health"
ollama_health = "https://curly-space-spork-v9rg679gpqw3rj6-11434.app.github.dev/api/health"
qdrant_health = "https://curly-space-spork-v9rg679gpqw3rj6-6333.app.github.dev/health"

[quick_reference]
# Common operations
"List workflows" = "curl -H 'X-N8N-API-KEY: {api_key}' {n8n_url}/api/v1/workflows"
"Test connection" = "curl -I https://curly-space-spork-v9rg679gpqw3rj6-5678.app.github.dev"
"Check Ollama models" = "curl https://curly-space-spork-v9rg679gpqw3rj6-11434.app.github.dev/api/tags"
"SSH to Codespace" = "gh codespace ssh --codespace curly-space-spork-v9rg679gpqw3rj6"
