{
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.env.linux": {
    "MEMORY_GUARD": "enabled",
    "GOROOT": "/usr/local/go",
    "GOPATH": "/root/go",
    "PATH": "/usr/local/go/bin:/root/go/bin:/usr/local/bin:/root/.local/bin:${env:PATH}"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.terminal.activateEnvironment": false,
  "python.defaultInterpreterPath": "uv",
  "files.watcherExclude": {
    "**/n8n-data/**": true,
    "**/ollama_storage/**": true,
    "**/postgres_storage/**": true,
    "**/qdrant_storage/**": true,
    "**/.venv/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/__pycache__": true
  },
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "go.goroot": "/usr/local/go",
  "go.toolsGopath": "/root/go",
  "go.alternateTools": {
    "go": "/usr/local/go/bin/go"
  },
  "copilot.advanced": {
    "debug.testingEnabled": true
  },
  "typespec.disable": true,
  // Plan Agent - Architecture + Symbolic Analysis + GitHub Actions
  "github.copilot.chat.planAgent.additionalTools": [
    "memory",
    "context7",
    "github",
    "vscode/askQuestions",
    "vscode/getProjectSetupInfo",
    "memory/add_observations",
    "memory/read_graph",
    "search/codebase",
    "search/fileSearch",
    "search/textSearch",
    "execute/runCommand",
    "execute/runInTerminal",
    "execute/getTerminalOutput",
    "execute/runTask",
    "execute/runTests",
    "github/create_branch",
    "github/create_pull_request",
    "github/list_branches",
    "github/list_pull_requests",
    "github/search_code",
    "github/get_file_contents",
    "time/get_current_time",
    "time/convert_time",
    "awesome-copilot/load_instruction",
    "awesome-copilot/search_instructions"
  ],
  // Ask Agent - Quick lookups + Symbol queries
  "github.copilot.chat.askAgent.additionalTools": [
    "memory",
    "time",
    "awesome-copilot",
    "vscode/askQuestions",
    "vscode/getProjectSetupInfo",
    "memory/add_observations",
    "memory/read_graph",
    "search/codebase",
    "search/fileSearch",
    "search/textSearch",
    "execute/runCommand",
    "execute/runInTerminal",
    "execute/getTerminalOutput",
    "execute/runTask",
    "execute/runTests",
    "github/create_branch",
    "github/create_pull_request",
    "github/list_branches",
    "github/list_pull_requests",
    "github/search_code",
    "github/get_file_contents",
    "time/get_current_time",
    "time/convert_time",
    "awesome-copilot/load_instruction",
    "awesome-copilot/search_instructions"
  ],
  "[copilot].mcp": {
    "servers": [
      {
        "name": "generateagents-mcp",
        "description": "GenerateAgents.md MCP Server - Expose AGENTS.md generation as LLM-callable tools",
        "command": "bash",
        "args": [
          "-c",
          "cd generateagents-mcp && uv run python server.py"
        ],
        "env": {
          "PYTHONPATH": "/workspaces/mcapp-ai-starter",
          "LOG_LEVEL": "INFO",
          "PATH": "/root/.local/bin:/usr/local/bin:/usr/bin:/bin"
        }
      }
    ]
  },
  "markdown.validate.enabled": true,
  "chat.useClaudeHooks": true,
  "chat.useCustomAgentHooks": true,
  "files.autoSave": "afterDelay",
  "chat.agent.enabled": true,
  "github.copilot.chat.allowTerminalAccess": true,
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/bin/bash",
      "args": []
    }
  },
  "terminal.integrated.developerMode": true,
  "git.rememberPostCommitCommand": true,
  "fastapi.telemetry.enabled": false,
  "github.copilot.chat.cli.planExitMode.enabled": true,
  "github.copilot.chat.githubMcpServer.toolsets": [
    "all"
  ],
  "github.copilot.chat.cli.branchSupport.enabled": true,
  "github.copilot.chat.cli.sessionController.enabled": true,
  "chat.tools.terminal.autoApprove": {
    "approve": true,
    "matchCommandLine": true,
    "/^set -e\ncd /workspaces/mcapp-ai-starter\nprintf \"Repo status before maintenance:\\\\n\"\ngit status --short\nprintf \"\\\\nCurrent branch: \"\ngit branch --show-current\nprintf \"\\\\nNode/npm: \"\nnode -v && npm -v\n$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
  "chat.mcp.serverSampling": {
    "allowedModels": {
      "default": "Auto"
    }
  },
  "promptregistry.repositoryOwner": "Ditto190",
  "promptregistry.updateCheck.autoUpdate": true,
  "[ql]": {
    "editor.defaultFormatter": "GitHub.vscode-codeql"
  },
  "python.analysis.typeCheckingMode": "basic",
  "github.copilot.chat.additionalReadAccessPaths": [
    "/workspaces/mcapp-ai-starter",
    "/usr/local/bin",
    "/root/.local/bin",
    "/usr/bin"
  ],
  "chat.subagents.allowInvocationsFromSubagents": true,
  "scm.repositories.explorer": true,
  "scm.repositories.selectionMode": "single",
  "editor.aiStats.enabled": true,
  "workbench.commandPalette.experimental.suggestCommands": true,
  "workbench.experimental.cloudChanges.autoStore": "onShutdown",
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true
  }
}