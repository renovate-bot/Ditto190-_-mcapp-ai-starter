# Codespaces-Optimized Environment Variables
# Copy relevant values from .env.example and customize below

# Database Configuration
POSTGRES_USER=root
POSTGRES_PASSWORD=codespaces_dev_password_change_me
POSTGRES_DB=n8n

# n8n Encryption & Security
# Generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32
N8N_USER_MANAGEMENT_JWT_SECRET=generate_with_openssl_rand_base64_32

# n8n Server Configuration
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Diagnostics OFF for reduced memory footprint
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# Ollama Configuration (Docker service name)
OLLAMA_HOST=ollama:11434
