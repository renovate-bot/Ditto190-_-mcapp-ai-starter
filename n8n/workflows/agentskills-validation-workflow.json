                    "responseHeaders": {
                        "entries": [
                            {
                                "name": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "name": "X-Validation-Status",
                                "value": "invalid"
                            }
                        ]
                    }
                }
            },
            "id": "respond-failure",
            "name": "Respond Failure",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                1560,
                420
            ]
        },
        {
            "parameters": {
                "operation": "create",
                "docType": "validation_log",
