{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:allNonMajor"
  ],
  "schedule": ["before 9am on Monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Automerge patch-level npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Group Docker base image updates together",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "Docker images"
    },
    {
      "description": "Group Python uv/pip updates",
      "matchManagers": ["uv", "pip_requirements"],
      "groupName": "Python dependencies"
    }
  ]
}

