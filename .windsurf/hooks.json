{
  "hooks": {
    "pre_mcp_tool_use": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "show_output": true
      }
    ],
    "pre_user_prompt": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook user-prompt-submit"
      }
    ],
    "pre_read_code": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "show_output": true
      }
    ],
    "pre_write_code": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "show_output": true
      }
    ],
    "pre_run_command": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook pre-tool-use",
        "show_output": true
      }
    ],
    "post_write_code": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook post-tool-use",
        "show_output": false
      }
    ],
    "post_mcp_tool_use": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook post-tool-use",
        "show_output": false
      }
    ],
    "post_cascade_response_with_transcript": [
      {
        "command": "npx -y @contextstream/mcp-server@latest hook session-end"
      }
    ]
  }
}