# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

# ── n8n Security (generate with: openssl rand -base64 32) ────────────────────
N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# ── n8n API access (optional, for agent/headless use) ────────────────────────
# N8N_API_KEY=your-n8n-api-key-here

# ── n8n Diagnostics (off = lighter memory footprint) ─────────────────────────
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false

# ── Ollama ─────────────────────────────────────────────────────────────────────
# Docker service name (inside the compose network)
# OLLAMA_HOST=ollama:11434
# Mac users running Ollama locally:
# OLLAMA_HOST=host.docker.internal:11434

# ── LLM API Keys (optional — Ollama works without any) ────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENROUTER_API_KEY=sk-or-...

# ── GenerateAgents.md defaults ────────────────────────────────────────────────
# GENERATEAGENTS_MODEL=ollama/phi:latest


