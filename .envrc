#!/usr/bin/env bash
# Direnv foundation for this repository
# Non-breaking baseline: safe defaults only, no mandatory tooling assumptions.

# -----------------------------
# Project-local PATH additions
# -----------------------------
path_add scripts
path_add .devcontainer/scripts

# -----------------------------
# Optional local bins
# -----------------------------
if [ -d "$PWD/.bin" ]; then
  path_add "$PWD/.bin"
fi

# Keep uv-installed tools visible if present
if [ -d "$HOME/.local/bin" ]; then
  path_add "$HOME/.local/bin"
fi

# -----------------------------
# Safe defaults (non-secret)
# -----------------------------
export UV_SYSTEM_PYTHON="${UV_SYSTEM_PYTHON:-1}"
export COMPOSE_DOCKER_CLI_BUILD="${COMPOSE_DOCKER_CLI_BUILD:-1}"
export DOCKER_BUILDKIT="${DOCKER_BUILDKIT:-1}"

# -----------------------------
# Optional Nix integration
# -----------------------------
# If nix + flake support are available, direnv will load devShell from flake.nix.
# This is intentionally optional to avoid breaking current workflows.
if command -v nix >/dev/null 2>&1; then
  if nix --extra-experimental-features "nix-command flakes" flake show >/dev/null 2>&1; then
    use flake
  fi
fi

# -----------------------------
# Optional .env loading (opt-in)
# -----------------------------
# Prevent accidental secret auto-export. Developers can enable explicitly:
#   export DIRENV_LOAD_DOTENV=1
if [ "${DIRENV_LOAD_DOTENV:-0}" = "1" ] && [ -f .env ]; then
  dotenv_if_exists .env
fi
