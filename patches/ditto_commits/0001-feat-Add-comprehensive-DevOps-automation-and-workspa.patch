+      - 'awesome-copilot/skills/**'
+  push:
+    branches: [main, master]
+    paths:
+      - 'awesome-copilot/skills/**'
+  workflow_dispatch:
+
+jobs:
+  validate:
+    runs-on: ubuntu-latest
+    
+    steps:
+      - name: Checkout code
+        uses: actions/checkout@v4
+      
+      - name: Set up Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: '3.11'
+      
+      - name: Install uv
+        run: |
+          curl -LsSf https://astral.sh/uv/install.sh | sh
+          echo "$HOME/.cargo/bin" >> $GITHUB_PATH
+      
+      - name: Install skills-ref
+        run: |
+          cd agentskills/skills-ref
+          uv sync
+      
+      - name: Validate all skills
+        id: validate
+        run: |
+          source agentskills/skills-ref/.venv/bin/activate
+          cd awesome-copilot/skills
+          
+          FAILED=0
+          FAILED_SKILLS=""
+          TOTAL=0
+          
+          for skill in */; do
+            if [ -d "$skill" ]; then
+              TOTAL=$((TOTAL + 1))
+              echo "::group::Validating: $skill"
+              if ! skills-ref validate "$skill" 2>&1; then
+                echo "❌ Failed: $skill"
+                FAILED=$((FAILED + 1))
+                FAILED_SKILLS="$FAILED_SKILLS\n- $skill"
+              else
+                echo "✅ Passed: $skill"
+              fi
+              echo "::endgroup::"
+            fi
+          done
+          
+          echo "total=$TOTAL" >> $GITHUB_OUTPUT
+          echo "failed=$FAILED" >> $GITHUB_OUTPUT
+          echo "passed=$((TOTAL - FAILED))" >> $GITHUB_OUTPUT
+          
+          if [ $FAILED -gt 0 ]; then
+            echo "❌ $FAILED skill(s) failed validation out of $TOTAL total"
+            echo -e "Failed skills:$FAILED_SKILLS"
+            exit 1
+          fi
+          
+          echo "✅ All $TOTAL skills passed AgentSkills validation"
+      
+      - name: Generate validation report
+        if: always()
+        run: |
+          source agentskills/skills-ref/.venv/bin/activate
+          cd awesome-copilot/skills
+          
+          cat > validation-report.md << 'REPORT_START'
+          # AgentSkills Validation Report
+          
+          **Date:** $(date -u +"%Y-%m-%d %H:%M:%S UTC")  
+          **Commit:** ${{ github.sha }}  
+          **Branch:** ${{ github.ref_name }}  
+          
+          ## Summary
+          
+          - **Total Skills:** ${{ steps.validate.outputs.total }}
+          - **✅ Passed:** ${{ steps.validate.outputs.passed }}
+          - **❌ Failed:** ${{ steps.validate.outputs.failed }}
+          
+          ## Details
+          
+          REPORT_START
+          
+          for skill in */; do
+            if [ -d "$skill" ]; then
+              echo "### $(basename "$skill")" >> validation-report.md
+              if skills-ref validate "$skill" >> validation-report.md 2>&1; then
+                echo "✅ **Status:** Valid" >> validation-report.md
+              else
+                echo "❌ **Status:** Failed" >> validation-report.md
+              fi
+              echo "" >> validation-report.md
+            fi
+          done
+      
+      - name: Upload validation report
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: agentskills-validation-report
+          path: awesome-copilot/skills/validation-report.md
+          retention-days: 30
+      
+      - name: Comment on PR
+        if: github.event_name == 'pull_request' && failure()
+        uses: actions/github-script@v7
+        with:
+          script: |
+            const fs = require('fs');
+            let report = '';
+            try {
+              report = fs.readFileSync('awesome-copilot/skills/validation-report.md', 'utf8');
+            } catch (e) {
+              report = 'Validation report not available';
+            }
+            
+            const body = `## ❌ AgentSkills Validation Failed
+            
+            **Failed:** ${{ steps.validate.outputs.failed }} / ${{ steps.validate.outputs.total }} skills
+            
+            <details>
+            <summary>View Full Report</summary>
+            
+            ${report}
+            
+            </details>
+            
+            ### How to Fix
+            
+            1. Review the validation errors above
+            2. Common issues:
+               - Invalid YAML syntax (use block style for lists, not flow style with \`['...']\`)
+               - Custom fields must be in \`metadata:\` section
+               - Name must match directory name
+               - Description must be 1-1024 characters
+            3. Test locally: \`cd agentskills/skills-ref && .venv/bin/skills-ref validate ../../awesome-copilot/skills/YOUR-SKILL\`
+            4. See: https://agentskills.io/specification
+            `;
+            
+            github.rest.issues.createComment({
+              issue_number: context.issue.number,
+              owner: context.repo.owner,
+              repo: context.repo.repo,
+              body: body
+            });
+      
+      - name: Set job summary
+        if: always()
+        run: |
+          echo "## AgentSkills Validation Results" >> $GITHUB_STEP_SUMMARY
+          echo "" >> $GITHUB_STEP_SUMMARY
+          echo "- **Total Skills:** ${{ steps.validate.outputs.total }}" >> $GITHUB_STEP_SUMMARY
+          echo "- **✅ Passed:** ${{ steps.validate.outputs.passed }}" >> $GITHUB_STEP_SUMMARY
+          echo "- **❌ Failed:** ${{ steps.validate.outputs.failed }}" >> $GITHUB_STEP_SUMMARY
+          echo "" >> $GITHUB_STEP_SUMMARY
+          
+          if [ "${{ steps.validate.outputs.failed }}" -eq "0" ]; then
+            echo "✅ **All skills passed AgentSkills validation!**" >> $GITHUB_STEP_SUMMARY
+          else
+            echo "❌ **Some skills failed validation. See artifacts for full report.**" >> $GITHUB_STEP_SUMMARY
+          fi
