+      "openapi": emitOpenAPI(spec)
+    };
+
+    for (const [format, content] of Object.entries(emitters)) {
+      const outPath = path.join("./emitted", format, stripExt(specFile) + ext);
+      fs.writeFileSync(outPath, JSON.stringify(content, null, 2));
+    }
+  }
+
